<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppNotaShrimp.MainPage">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">
            <Label Text="Mis notas" TextColor="AliceBlue" FontSize="Body"/>
            <CollectionView ItemsSource="{Binding listNotas}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="DarkBlue" BackgroundColor="LightBlue" CornerRadius="10" Padding="10" Margin="5">
                            <StackLayout>
                                <Label Text="{Binding Title}" FontSize="Title" FontAttributes="Bold"/>
                                <Label Text="{Binding Content}" FontSize="Body"/>
                                <Label Text="{Binding CreatedAt, StringFormat='Fecha: {0:dd/MM/yyyy}'}" FontSize="Caption"/>
                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                 </CollectionView.ItemTemplate>

            </CollectionView>


        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
